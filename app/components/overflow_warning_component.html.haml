= render Pajamas::AlertComponent.new(title: _('algumas mudanças não são mostradas.'),
    variant: :warning,
    alert_options: { class: 'dw-mb-5', data: { testid: "too-many-changes-alert" } }) do |c|
    = c.with_body do
        = message

    = c.with_actions do
        = diff_link
        = patch_link